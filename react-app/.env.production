# Production API base URL — used automatically by `npm run build`.
# Dev (`npm run dev`) ignores this and defaults to http://localhost:4000/api.
VITE_API_URL=https://bayareaaccountingsolutions.com/api

# WhatsApp support number (country code + number, digits only, no +).
# Example: 15551234567. Leave blank to hide the WhatsApp button.
VITE_WHATSAPP_NUMBER=
