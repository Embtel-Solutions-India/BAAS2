PORT=4000
NODE_ENV=development

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/baas_portal

# ── JWT ──
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── Email / Nodemailer ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Bay Area Accounting Solutions <noreply@bayareaaccountingsolutions.com>"

# ── Frontend base URL (used in email links + CORS) ──
# Comma-separate multiple origins e.g. http://localhost:8000,https://yoursite.com
CLIENT_URL=http://localhost:8000

# ── File uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ── AWS S3 (Blog Thumbnails) ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_BUCKET_NAME=your_bucket_name

# ── QuickBooks Payments ──
# Create an app at https://developer.intuit.com (Payments scope)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback
# sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox
# Optional: pre-seed a connection (otherwise use the admin "Connect QuickBooks" flow)
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REFRESH_TOKEN=
# Webhook verifier token from the Intuit developer dashboard (webhooks section)
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
# Payments >= this amount create a "large payment" admin activity alert
QUICKBOOKS_LARGE_PAYMENT_THRESHOLD=1000

# ── Client OTP login ──
# Email OTP works out of the box using the EMAIL_* settings above. If email is
# not configured, in non-production the code is logged to the server console and
# returned as `devCode` for testing. No extra vars required.

# ── Client OAuth (OPTIONAL, gated) ──
# Each provider activates only when its client id + secret are set. Redirect URI
# to register in the provider console: {OAUTH_REDIRECT_BASE}/api/auth/oauth/<provider>/callback
OAUTH_REDIRECT_BASE=http://localhost:4000
# Google — https://console.cloud.google.com (OAuth consent + credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft — https://portal.azure.com (App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ── SMS (OPTIONAL, future — not enabled) ──
# Mobile OTP is structured but off. Add a provider (Twilio/SNS/etc.) later:
# SMS_PROVIDER=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
