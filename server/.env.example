PORT=4000
NODE_ENV=development

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/baas_portal

# ── JWT ──
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── Email / Nodemailer ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Bay Area Accounting Solutions <noreply@bayareaaccountingsolutions.com>"

# ── Frontend base URL (used in email links + CORS) ──
# Comma-separate multiple origins e.g. http://localhost:8000,https://yoursite.com
CLIENT_URL=http://localhost:8000

# ── File uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ── AWS S3 (Blog Thumbnails) ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_BUCKET_NAME=your_bucket_name

# ── QuickBooks Payments ──
# Create an app at https://developer.intuit.com (Payments scope)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback
# sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox
# Optional: pre-seed a connection (otherwise use the admin "Connect QuickBooks" flow)
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REFRESH_TOKEN=
# Webhook verifier token from the Intuit developer dashboard (webhooks section)
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=
# Payments >= this amount create a "large payment" admin activity alert
QUICKBOOKS_LARGE_PAYMENT_THRESHOLD=1000
